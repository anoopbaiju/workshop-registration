# Google Sheets — see README for setup steps
GOOGLE_SHEET_ID=your_google_sheet_id_from_url

# Local dev: path to JSON key file
GOOGLE_SERVICE_ACCOUNT_FILE=credentials/service-account.json

# Render/production: paste full JSON key contents (one line) instead of file
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Contact shown on the registration page
ORG_WHATSAPP_DISPLAY=+91 95676 02762
ORG_WHATSAPP_LINK=https://wa.me/919567602762

# UPI payment
UPI_VPA=alwaysdevu@ybl
UPI_PAYEE_NAME=DEVU M
WORKSHOP_PRICE_PER_SEAT=3000

# Optional: restrict CORS in production (comma-separated origins)
# ALLOWED_ORIGINS=https://your-domain.com

# Organizer admin page (/admin) — pick a strong password
ADMIN_SECRET=change-me-to-a-strong-password

# Server port
PORT=8080

