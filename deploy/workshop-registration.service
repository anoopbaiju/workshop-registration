[Unit]
Description=Terrarium Workshop Registration
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/workshop-registration
Environment=PATH=/root/workshop-registration/venv/bin:/usr/bin
EnvironmentFile=/root/workshop-registration/.env
ExecStart=/root/workshop-registration/venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8080
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
